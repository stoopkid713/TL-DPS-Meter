# Personal runtime data — mutated by running the app; NOT shipped (the app seeds
# its presets on first run). Use samples/encounters_sample.json for testing.
# (Tracked presets that ARE shipped: default_target_assignments.json, dungeons.json,
#  skill_settings.json, weapon_config.json.)
encounters.json
saved_runs.json
config.json
target_assignments.json

# Pyinstaller extraction artifacts
*.exe_extracted/
pyinstxtractor.py

# Build outputs (PyInstaller, manual builds)
/dist/
/build/
*.spec.bak

# Historical archives (preserved in working tree, not in git)
/archive/
/data-archive/

# Python
__pycache__/
*.pyc

# Game-data refresh tool: raw questlog pull cache (regenerated on demand)
backend/tools/_refresh_cache/

# Local tooling (Claude Code preview config, etc.) — not shipped
.claude/

# Tauri overlay (Rust) build artifacts + generated files
overlay/src-tauri/target/
overlay/src-tauri/gen/

_test-obs.mjs
.obs-key
obs.mjs

# Wrangler local auth/account cache — never commit
.wrangler/

# Scratch / debug probes (underscore convention) — not shipped
backend/tools/_bots_join.py
tests/frontend/_cdp_*.js
